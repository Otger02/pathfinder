{
  "name": "pathfinder",
  "version": "1.0.0",
  "description": "A knowledge base container for immigration information and resources",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "convert": "tsx scripts/convert-documents.ts",
    "chunk": "tsx scripts/chunk-legislation.ts && tsx scripts/chunk-authorizations.ts && tsx scripts/chunk-guides.ts",
    "ingest": "tsx scripts/embed-and-ingest.ts",
    "pipeline": "npm run convert && npm run chunk && npm run ingest",
    "test:engine": "npx tsx scripts/test-collection-engine.ts",
    "test:rules": "npx tsx scripts/test-collection-rules.ts",
    "test:prompt": "npx tsx scripts/test-prompt-builder.ts",
    "test:email": "npx tsx scripts/test-email-draft.ts",
    "test:e2e": "npx tsx scripts/test-chat-flow.ts",
    "test:arraigo": "npx tsx scripts/test-conversation-arraigo.ts",
    "test": "npm run test:engine && npm run test:rules && npm run test:prompt && npm run test:email",
    "seed:otger": "npx tsx scripts/seed-otger.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/postcss": "^4.2.2",
    "canvas": "^3.2.3",
    "fflate": "^0.8.2",
    "next": "^15.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  }
}
